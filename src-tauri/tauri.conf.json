{
  "productName": "WHYAPP",
  "version": "0.1.0",
  "identifier": "com.whyapp.superapp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "distDir": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WHYAPP | 100% Magnum Opus",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' ws: wss: https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "WHYAPP God Engineering",
    "category": "SocialNetworking",
    "windows": {
      "nsis": {
        "oneClick": true,
        "perMachine": false,
        "allowElevation": true,
        "allowToChangeInstallationDirectory": true,
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "uninstallDisplayName": "WHYAPP Uninstaller",
        "license": null,
        "artifactName": "WHYAPP-God-Engine-Setup-${version}.${arch}.exe"
      }
    }
  }
}
